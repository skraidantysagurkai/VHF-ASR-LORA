- name: random_noise_gate
  id: epy_block
  parameters:
    affinity: ''
    alias: ''
    comment: Randomly toggles impulse/uniform/tone noise on and off
    _source_code: "import numpy as np\nimport pmt\nfrom gnuradio import gr\n\nclass\
      \ blk(gr.sync_block):\n    def __init__(self, samp_rate=480000):\n        gr.sync_block.__init__(\
      self,\n            name='Random Noise Gate',\n            in_sig=[np.float32],\n\
      \            out_sig=[np.float32])\n        self.samp_rate = samp_rate\n    \
      \    self.counter = 0\n        self.next_toggle = int(samp_rate * np.random.uniform(0.5,\
      \ 3.0))\n        self.gates = {'impulse': 0.0, 'uniform': 0.0, 'tone': 0.0}\n\
      \        for name in self.gates:\n            self.message_port_register_out(pmt.intern(name))\n\
      \n    def work(self, input_items, output_items):\n        n = len(input_items[0])\n\
      \        output_items[0][:] = input_items[0]\n        self.counter += n\n  \
      \      if self.counter >= self.next_toggle:\n            self.counter = 0\n\
      \            self.next_toggle = int(self.samp_rate * np.random.uniform(0.5,\
      \ 3.0))\n            for name in self.gates:\n                if np.random.random()\
      \ < 0.4:\n                    self.gates[name] = 1.0 - self.gates[name]\n  \
      \                  self.message_port_pub(\n                        pmt.intern(name),\n\
      \                        pmt.cons(pmt.intern('val'), pmt.from_float(self.gates[name])))\n\
      \        return n\n"
    samp_rate: samp_rate
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [600, 484]
    rotation: 0
    state: enabled

connections:
# --- original chain (with blocks_add_xx_0 replaced by blocks_add_channel) ---
- [blocks_wavfile_source_0, '0', high_pass_filter_0, '0']
- [high_pass_filter_0, '0', low_pass_filter_0, '0']
- [low_pass_filter_0, '0', mmse_resampler_xx_0, '0']
- [mmse_resampler_xx_0, '0', blocks_throttle_0, '0']
- [blocks_throttle_0, '0', blocks_multiply_const_vxx_0, '0']
- [blocks_multiply_const_vxx_0, '0', blocks_add_const_vxx_0, '0']
- [blocks_add_const_vxx_0, '0', blocks_multiply_xx_0, '0']
- [analog_sig_source_x_0, '0', blocks_multiply_xx_0, '1']
# AM signal passes through random_noise_gate (passthrough) which also sends messages
- [blocks_multiply_xx_0, '0', random_noise_gate, '0']
- [random_noise_gate, '0', blocks_add_channel, '0']
# AWGN always on
- [analog_noise_source_x_0, '0', blocks_add_channel, '1']
# random noise mix
- [blocks_add_noise_mix, '0', blocks_add_channel, '2']
# output of channel mixer into demod
- [blocks_add_channel, '0', blocks_abs_xx_0, '0']
- [blocks_add_channel, '0', qtgui_freq_sink_x_0, '0']
- [blocks_abs_xx_0, '0', blocks_add_const_vxx_1, '0']
- [blocks_add_const_vxx_1, '0', low_pass_filter_1, '0']
- [low_pass_filter_1, '0', mmse_resampler_xx_1, '0']
- [mmse_resampler_xx_1, '0', audio_sink_0, '0']
