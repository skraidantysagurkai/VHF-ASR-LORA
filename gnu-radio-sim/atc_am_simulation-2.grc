    bits_per_sample1: FORMAT_PCM_16
    bits_per_sample2: FORMAT_PCM_16
    bits_per_sample3: FORMAT_VORBIS
    bits_per_sample4: FORMAT_PCM_16
    comment: Output recovered audio
    file: /Users/ezka/Documents/output.wav
    format: FORMAT_WAV
    nchan: '1'
    samp_rate: '16000'
  states:
    bus_sink: false
