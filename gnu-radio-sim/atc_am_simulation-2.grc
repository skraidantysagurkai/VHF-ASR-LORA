    affinity: ''
    alias: ''
    comment: Upsample 16kHz -> 480kHz for simulation
    maxoutbuf: '0'
    minoutbuf: '0'
    phase_shift: '0'
    resamp_ratio: float(audio_rate)/float(samp_rate)
